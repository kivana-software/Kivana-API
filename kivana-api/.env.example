# Example environment configuration for local development / docker-compose.
# Copy to `.env` and adjust values as needed.
#
# Backend (Rust/Axum) runtime:
# - DATABASE_URL: Postgres connection string used by SQLx.
# - JWT_SECRET: Secret used to sign/verify JWTs (keep private; rotate if leaked).
# - ACCESS_TOKEN_TTL_SECONDS: Lifetime of access tokens (short-lived).
# - REFRESH_TOKEN_TTL_DAYS: Lifetime of refresh tokens (long-lived).
# - BIND_ADDR: Address/port the HTTP server binds to.
# - ADMIN_TOKEN: One-time bootstrap token for admin setup endpoints.
# - RUST_LOG: Tracing/log verbosity (uses `tracing_subscriber` env filter).
#
# Docker-compose helpers:
# - KIVANA_HTTP_PORT: Host port that maps to the container's HTTP port.
# - POSTGRES_PASSWORD: Password for the Postgres container user.

DATABASE_URL=postgres://kivana:kivana_password@db:5432/kivana
JWT_SECRET=CHANGE_ME_TO_32+_RANDOM_CHARS
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
BIND_ADDR=0.0.0.0:8080
ADMIN_TOKEN=CHANGE_ME
RUST_LOG=info
KIVANA_HTTP_PORT=80
POSTGRES_PASSWORD=kivana_password
